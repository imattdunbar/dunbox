{
  "name": "dunbox",
  "private": true,
  "homepage": "https://github.com/imattdunbar/dunbox#readme",
  "bugs": {
    "url": "https://github.com/imattdunbar/dunbox/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imattdunbar/dunbox.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "bunup",
    "dev": "bunup --watch",
    "release": "bumpp -r --commit --push --tag",
    "typecheck": "bun run --filter '*' typecheck"
  },
  "catalog": {
    "@types/bun": "1.3.9",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "prettier": "^3.8.1",
    "bumpp": "^10.4.1",
    "bunup": "^0.16.31",
    "typescript": "catalog:"
  },
  "prettier": {
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "none",
    "semi": false,
    "printWidth": 120
  }
}
